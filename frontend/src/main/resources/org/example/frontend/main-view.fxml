<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.controller.MainController">

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #3f51b5; -fx-padding: 12;">
        <Label text="سامانه خرید و فروش دست دوم" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="پیام‌ها" onAction="#onGoToChatsClick" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="ثبت آگهی جدید" onAction="#onNewAdClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="علاقه‌مندی‌ها" onAction="#onGoToFavoritesClick" style="-fx-background-color: #E91E63; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="خروج" onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0;">
        <TextField fx:id="searchField" promptText="جست‌وجوی کلمه کلیدی..." prefWidth="180"/>
        <TextField fx:id="categoryFilterField" promptText="دسته بندی..." prefWidth="100"/>
        <TextField fx:id="cityFilterField" promptText="شهر..." prefWidth="80"/>
        <TextField fx:id="minPriceField" promptText="حداقل قیمت..." prefWidth="100"/>
        <TextField fx:id="maxPriceField" promptText="حداکثر قیمت..." prefWidth="100"/>
        <Button text="جست‌وجو و فیلتر" onAction="#onSearchClick" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    </HBox>

    <SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <VBox spacing="10" style="-fx-padding: 10;">
            <Label text="آگهی‌های فعال" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <ListView fx:id="adsListView" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="15" style="-fx-padding: 15;">
            <Label text="جزئیات کامل آگهی" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 5 0;"/>
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="80"/>
                </columnConstraints>

                <Label text="عنوان:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="titleLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Label text="قیمت:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="priceLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="شهر:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="cityLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="دسته‌بندی:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="categoryLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="فروشنده:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="ownerLabel" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>

            <Label text="توضیحات:" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="descriptionArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
        </VBox>
    </SplitPane>
</VBox>