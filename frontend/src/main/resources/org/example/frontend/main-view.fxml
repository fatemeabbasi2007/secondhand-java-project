<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.controller.MainController">

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #3f51b5; -fx-padding: 12;">
        <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="سامانه خرید و فروش دست دوم" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onGoToChatsClick" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;" text="پیام‌ها" />
        <Button onAction="#onNewAdClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="ثبت آگهی جدید" />
        <Button onAction="#onGoToFavoritesClick" style="-fx-background-color: #E91E63; -fx-text-fill: white; -fx-font-weight: bold;" text="علاقه‌مندی‌ها" />
        <Button onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="خروج" />
    </HBox>

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0;">
        <TextField fx:id="searchField" prefWidth="180" promptText="جست‌وجوی کلمه کلیدی..." />
        <VBox spacing="5.0">
            <Label text="دسته‌بندی" textFill="#57606F" />
            <ComboBox fx:id="categoryComboBox" prefWidth="300.0" promptText="انتخاب کنید..." style="-fx-background-color: #F1F2F6; -fx-background-radius: 5;" />
        </VBox>
        <TextField fx:id="cityFilterField" prefWidth="80" promptText="شهر..." />
        <TextField fx:id="minPriceField" prefWidth="100" promptText="حداقل قیمت..." />
        <TextField fx:id="maxPriceField" prefWidth="100" promptText="حداکثر قیمت..." />
        <Button onAction="#onSearchClick" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="جست‌وجو و فیلتر" />
    </HBox>

    <SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <VBox spacing="10" style="-fx-padding: 10;">
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="آگهی‌های فعال" />
            <ListView fx:id="adsListView" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox spacing="15" style="-fx-padding: 15;">
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 5 0;" text="جزئیات کامل آگهی" />
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20.0" />
                    <ColumnConstraints percentWidth="20.0" />
               <ColumnConstraints percentWidth="80.0" />
                </columnConstraints>

                <Label style="-fx-font-weight: bold;" text="عنوان:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="titleLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="-" GridPane.columnIndex="2" />

                <Label style="-fx-font-weight: bold;" text="قیمت:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label fx:id="priceLabel" text="-" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight: bold;" text="شهر:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="cityLabel" text="-" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                <Label style="-fx-font-weight: bold;" text="دسته‌بندی:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label fx:id="categoryLabel" text="-" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight: bold;" text="عکس:" GridPane.rowIndex="4" />
                <Label fx:id="imageLabel" text="-" GridPane.columnIndex="2" GridPane.rowIndex="4" />

                <Label style="-fx-font-weight: bold;" text="فروشنده:" GridPane.rowIndex="6" />
                <Label fx:id="ownerLabel" text="-" GridPane.columnIndex="2" GridPane.rowIndex="6" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <Label style="-fx-font-weight: bold;" text="توضیحات:" />
            <TextArea fx:id="descriptionArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />
        </VBox>
    </SplitPane>
</VBox>
