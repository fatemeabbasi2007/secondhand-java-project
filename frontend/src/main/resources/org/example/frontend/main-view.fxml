<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<BorderPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.frontend.controller.MainController">

    <left>
        <VBox spacing="10.0" style="-fx-background-color: #2F3542;" prefWidth="220.0">
            <padding>
                <Insets top="25.0" right="15.0" bottom="20.0" left="15.0"/>
            </padding>

            <Label text="دیوار دانشجویی" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="15.0" />
                </VBox.margin>
            </Label>

            <Label fx:id="roleBadge" text="نقش: کاربر عادی" textFill="#A4B0BE">
                <font>
                    <Font size="12.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="10.0" />
                </VBox.margin>
            </Label>

            <Button fx:id="btnDashboard" text="🏠 داشبورد کالاها" onAction="#showDashboard" prefWidth="190.0"
                    style="-fx-background-color: #3742FA; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="btnAddItem" text="➕ ثبت آگاهی جدید" onAction="#showAddItemForm" prefWidth="190.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #A4B0BE; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="btnFavorites" text="⭐ علاقه‌مندی‌ها" onAction="#showFavorites" prefWidth="190.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #A4B0BE; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="btnChats" text="💬 چت‌ها و پیام‌ها" onAction="#showChats" prefWidth="190.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #A4B0BE; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="btnPendingAds" text="⏳ آگهی‌های منتظر تایید" onAction="#showPendingAds" prefWidth="190.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #A4B0BE; -fx-alignment: CENTER_LEFT;"/>

            <Button fx:id="btnManageUsers" text="👥 مدیریت کاربران" onAction="#showManageUsers" prefWidth="190.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #A4B0BE; -fx-alignment: CENTER_LEFT;"/>

            <VBox prefHeight="100.0" VBox.vgrow="ALWAYS" />

            <Button text="🚪 خروج از حساب" onAction="#handleLogout" prefWidth="190.0"
                    style="-fx-background-color: #FF4757; -fx-text-fill: white;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15.0" style="-fx-background-color: #F1F2F6;">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>

            <Label fx:id="pageTitle" text="کالاهای اخیر" textFill="#2F3542">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>

            <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;">
                <children>
                    <TextField fx:id="searchField" promptText="جست‌وجو در عنوان و توضیحات..." prefWidth="200.0" />

                    <ComboBox fx:id="filterCategoryComboBox" promptText="دسته‌بندی" prefWidth="120.0" />

                    <ComboBox fx:id="filterCityComboBox" promptText="شهر" prefWidth="90.0" />

                    <TextField fx:id="minPriceField" promptText="حداقل قیمت" prefWidth="90.0" />
                    <TextField fx:id="maxPriceField" promptText="حداکثر قیمت" prefWidth="90.0" />

                    <Button text="🔍 فیلتر" onAction="#handleSearchAndFilter"
                            style="-fx-background-color: #3742FA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
                    <Button text="🔄 ریست" onAction="#handleResetFilters"
                            style="-fx-background-color: #747D8C; -fx-text-fill: white; -fx-background-radius: 5;"/>
                </children>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F1F2F6;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="productsContainer" hgap="15.0" vgap="15.0">
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>