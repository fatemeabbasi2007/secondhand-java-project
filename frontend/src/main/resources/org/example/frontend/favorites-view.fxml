<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="450.0" prefWidth="600.0" spacing="15" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.frontend.controller.FavoritesController">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← بازگشت" onAction="#onBackClick" style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Label text="آگهی‌های نشانه‌گذاری شده (علاقه‌مندی‌ها)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #E91E63;"/>
    </HBox>

    <Separator/>

    <ListView fx:id="favoritesListView" VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="حذف از علاقه‌مندی‌ها" onAction="#onRemoveFavoriteClick" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 160; -fx-pref-height: 35;"/>
    </HBox>

</VBox>