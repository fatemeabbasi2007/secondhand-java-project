<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.controller.ChatController">

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #00796B; -fx-padding: 12;">
        <Button text="← بازگشت به صفحه اصلی" onAction="#onBackClick" style="-fx-background-color: #004D40; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Label text="صندوق ورودی پیام‌ها (چت)" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>

    <SplitPane dividerPositions="0.38" VBox.vgrow="ALWAYS">
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ECEFF1;">
            <Label text="مکالمات اخیر" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #37474F;"/>
            <ListView fx:id="conversationsListView" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="10" style="-fx-padding: 10;">
            <Label fx:id="activeChatTitleLabel" text="لطفاً یک گفت‌وگو را از لیست سمت چپ انتخاب کنید..." style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #00796B; -fx-padding: 0 0 5 0; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1px 0;"/>

            <ListView fx:id="messagesListView" VBox.vgrow="ALWAYS" style="-fx-background-color: #FAFAFA;"/>

            <Separator/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextArea fx:id="messageInputArea" promptText="پیام خود را بنویسید..." prefHeight="50.0" HBox.hgrow="ALWAYS" wrapText="true"/>
                <Button text="ارسال" onAction="#onSendMessageClick" style="-fx-background-color: #00796B; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 80; -fx-pref-height: 50;"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>