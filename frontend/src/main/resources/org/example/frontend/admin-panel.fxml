<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.controller.AdminPanelController">

    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
        <Label text="پنل مدیریت سامانه دست دوم" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="خروج از حساب" onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <Tab text="بررسی آگهی‌ها">
            <SplitPane dividerPositions="0.38">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="آگهی‌های در انتظار بررسی" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <ListView fx:id="pendingAdsListView" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="12" style="-fx-padding: 15;">
                    <Label text="اطلاعات آگهی" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 5 0;"/>
                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="20"/>
                            <ColumnConstraints percentWidth="80"/>
                        </columnConstraints>
                        <Label text="عنوان:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="titleLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="قیمت:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="priceLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="شهر:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="cityLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="دسته‌بندی:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="categoryLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        <Label text="ثبت‌کننده:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="ownerLabel" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>
                    <Label text="توضیحات:" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="descriptionArea" editable="false" wrapText="true" prefHeight="80.0"/>
                    <Separator/>
                    <VBox spacing="5">
                        <Label text="علت رد (فقط در صورت رد کردن آگهی):" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="reasonField" promptText="علت رد شدن..."/>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button text="حذف آگهی نامناسب" onAction="#onDeleteAdClick" style="-fx-background-color: #962d22; -fx-text-fill: white;"/>
                        <Button text="رد آگهی" onAction="#onRejectClick" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-pref-width: 80;"/>
                        <Button text="تایید آگهی" onAction="#onApproveClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-pref-width: 80;"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </Tab>

        <!-- اضافه کردن این تب به TabPane موجود در admin-panel.fxml -->
        <Tab text="مدیریت آگهی‌های فعال">
            <VBox spacing="10" style="-fx-padding: 15;">
                <Label text="لیست تمام آگهی‌های منتشرشده در سامانه:" style="-fx-font-weight: bold;" />

                <!-- لیست آگهی‌های فعال -->
                <ListView fx:id="activeAdsListView" VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="حذف آگهی انتخاب‌شده"
                            onAction="#onDeleteActiveAdClick"
                            style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" />
                </HBox>
            </VBox>
        </Tab>

        <Tab text="مدیریت کاربران">
            <SplitPane dividerPositions="0.38">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="لیست کاربران سیستم" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="اطلاعات کاربر انتخاب شده" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #ccc; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 5 0;"/>
                    <GridPane hgap="10" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="75"/>
                        </columnConstraints>
                        <Label text="نام کامل:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="userFullNameLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="نام کاربری:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="userUsernameLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="شماره تماس:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="userPhoneLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="ایمیل:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="userEmailLabel" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        <Label text="وضعیت حساب:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="userStatusLabel" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>
                    <Separator VBox.vgrow="ALWAYS" style="-fx-opacity: 0;"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="blockToggleButton" onAction="#onToggleBlockClick" text="تغییر وضعیت مسدودیت" style="-fx-font-weight: bold; -fx-pref-width: 150;"/>
                    </HBox>
                </VBox>
            </SplitPane>
        </Tab>
    </TabPane>
</VBox>