<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.frontend.controller.ProductDetailsController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Button text="⬅️ بازگشت به آگهی‌ها" onAction="#handleBack"
            style="-fx-background-color: #CED6E0; -fx-text-fill: #2F3542; -fx-font-weight: bold;"/>

    <HBox spacing="20.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" text="عنوان آگهی" textFill="#2F3542" style="-fx-font-weight: bold; -fx-font-size: 20.0;" />
            <HBox spacing="15.0">
                <Label fx:id="categoryLabel" text="دسته‌بندی: لپ‌تاپ" textFill="#747D8C" />
                <Label fx:id="cityLabel" text="شهر: تهران" textFill="#747D8C" />
            </HBox>
        </VBox>
        <Label fx:id="priceLabel" text="قیمت" textFill="#3742FA" style="-fx-font-weight: bold; -fx-font-size: 18.0;" />
    </HBox>

    <Separator style="-fx-background-color: #F1F2F6;"/>

    <VBox spacing="5.0" style="-fx-background-color: #F8F9FA; -fx-padding: 10; -fx-background-radius: 5;">
        <Label text="👤 اطلاعات فروشنده:" textFill="#2F3542" style="-fx-font-weight: bold; -fx-font-size: 12.0;" />
        <HBox spacing="20.0">
            <Label fx:id="sellerNameLabel" text="نام فروشنده: احمدی" textFill="#57606F" />
            <Label fx:id="sellerRatingLabel" text="امتیاز فروشنده: ⭐ ۴.۵ از ۵" textFill="#FFB142" style="-fx-font-weight: bold;" />
        </HBox>
    </VBox>

    <VBox spacing="5.0">
        <Label text="توضیحات آگهی:" textFill="#747D8C" style="-fx-font-weight: bold;" />
        <Label fx:id="descriptionLabel" text="توضیحات..." textFill="#2F3542" wrapText="true" />
    </VBox>

    <Label fx:id="soldStatusLabel" text="⚠️ این کالا فروخته شده است!" textFill="#FF4757" visible="false" style="-fx-font-weight: bold; -fx-font-size: 14.0;" />

    <Separator style="-fx-background-color: #F1F2F6;"/>

    <HBox fx:id="buyerActionsContainer" spacing="15.0">
        <Button fx:id="btnStartChat" text="💬 شروع گفتگو با فروشنده" onAction="#handleStartChat"
                style="-fx-background-color: #2ED573; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15;"/>
        <Button fx:id="btnFavorite" text="⭐ افزودن به علاقه‌مندی‌ها" onAction="#handleToggleFavorite"
                style="-fx-background-color: #FFB142; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15;"/>
    </HBox>

    <HBox fx:id="ownerActionsContainer" spacing="15.0" visible="false" managed="false">
        <Button text="✏️ ویرایش آگهی" onAction="#handleEditAd"
                style="-fx-background-color: #54A0FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15;"/>
        <Button text="❌ حذف آگهی" onAction="#handleDeleteAd"
                style="-fx-background-color: #FF4757; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15;"/>
        <Button fx:id="btnMarkAsSold" text="🤝 تغییر وضعیت به فروخته شده" onAction="#handleMarkAsSold"
                style="-fx-background-color: #1DD1A1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 15;"/>
    </HBox>

    <VBox fx:id="reviewSectionContainer" spacing="8.0">
        <Label text="امتیاز و نظر خود را درباره فروشنده ثبت کنید:" textFill="#2F3542" style="-fx-font-weight: bold;" />
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="امتیاز (از ۱ تا ۵):" textFill="#57606F" /><TextField fx:id="ratingField" prefWidth="50.0" promptText="5" style="-fx-alignment: CENTER;"/>
        </HBox>
        <TextArea fx:id="commentField" promptText="نظر خود را بنویسید..." prefHeight="50.0" wrapText="true"/>
        <Button fx:id="btnSubmitReview" text="ثبت نظر" onAction="#handleSubmitReview" style="-fx-background-color: #57606F; -fx-text-fill: white;"/>
    </VBox>

    <Label fx:id="statusLabel" textFill="#2ED573" />
</VBox>