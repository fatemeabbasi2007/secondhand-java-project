<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" spacing="15.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.frontend.controller.LoginController"
      style="-fx-padding: 40; -fx-pref-width: 400; -fx-pref-height: 400;">

    <Label text="ورود به سامانه" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>

    <TextField fx:id="usernameField" promptText="نام کاربری"/>
    <PasswordField fx:id="passwordField" promptText="رمز عبور"/>

    <Button text="ورود" onAction="#onLoginButtonClick" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 150;"/>

    <Button text="هنوز ثبت نام نکرده‌اید؟ ساخت حساب جدید" onAction="#onGoToRegisterClick" style="-fx-background-color: transparent; -fx-text-fill: #4CAF50; -fx-underline: true;"/>

</VBox>