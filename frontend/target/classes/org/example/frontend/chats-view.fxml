<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="500.0" prefWidth="750.0" spacing="10.0" style="-fx-background-color: #F1F2F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.controller.ChatsController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>

        <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label text="گفتگوهای فعال" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2F3542;" />
                <Separator />
                <ListView fx:id="chatListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" />
            </children>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <VBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <Label fx:id="chatTitleLabel" text="لطفاً یک گفتگو را انتخاب کنید" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2F3542;" />
                            <Label fx:id="adTitleLabel" text="" style="-fx-font-size: 11px; -fx-text-fill: #747D8C;" />
                        </VBox>
                    </children>
                </HBox>
                <Separator />

                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8F9FA; -fx-background-radius: 5;">
                    <content>
                        <VBox fx:id="messagesContainer" spacing="8.0" style="-fx-padding: 10;" />
                    </content>
                </ScrollPane>

                <HBox spacing="10.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnSendMessage" onAction="#handleSendMessage" text="ارسال 🚀" style="-fx-background-color: #3742FA; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold;" prefHeight="35.0" />
                        <TextField fx:id="messageInputField" HBox.hgrow="ALWAYS" promptText="پیام خود را بنویسید..." style="-fx-background-radius: 5; -fx-padding: 8;" prefHeight="35.0" />
                    </children>
                </HBox>
            </children>
        </VBox>

    </children>
</HBox>